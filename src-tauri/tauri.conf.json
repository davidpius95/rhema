{
  "$schema": "../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Rhema",
  "version": "1.0.15",
  "identifier": "com.openbezal.rhemaapp",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "bun dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "Rhema",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../data/rhema.db": "rhema.db",
      "../models/whisper": "models/whisper",
      "../models/qwen3-embedding-0.6b": "models/qwen3-embedding-0.6b",
      "../models/qwen3-embedding-0.6b-int8": "models/qwen3-embedding-0.6b-int8",
      "../sdk/ndi": "sdk/ndi",
      "../embeddings": "embeddings"
    },
    "macOS": {
      "entitlements": "Entitlements.macOS.plist",
      "minimumSystemVersion": "11.0"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
